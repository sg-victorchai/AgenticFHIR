# Example environment variables for the FHIR web application
# Copy this file to .env and fill in your actual values

# FHIR server base URL
VITE_FHIR_BASE_URL=https://api.example.com/fhir/r5/your-tenant-id

# SSE (Server-Sent Events) endpoint for real-time notifications
VITE_SSE_BASE_URL=http://localhost:8080

# API key for authentication with the FHIR server
VITE_API_KEY=your_api_key_here